{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Academic subject available for registration",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "credits": { "type": "number" },
        "capacity": { "type": "number" },
        "registeredCount": { "type": "number" }
      },
      "required": ["code", "name", "credits", "capacity"]
    },
    "Registration": {
      "title": "Registration",
      "description": "Record of a student pre-registering for a subject",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "subjectId": { "type": "string" },
        "subjectCode": { "type": "string" },
        "subjectName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["studentId", "subjectId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Available subjects"
    },
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Subject registrations"
    }
  }
}
